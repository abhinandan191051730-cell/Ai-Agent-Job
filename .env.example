# LLM Provider (choose one)
LLM_PROVIDER=openai       # openai, anthropic, google, ollama
LLM_API_KEY=sk-your-key-here
LLM_MODEL=gpt-4           # gpt-4, claude-3-opus, gemini-pro, ollama-model-name

# Optional: override with separate keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Playwright / Browser
HEADLESS=false
BROWSER_DATA_DIR=./data/browser_profile

# Application limits
MAX_APPLICATIONS_PER_RUN=200
LINKEDIN_DAILY_LIMIT=50
NAUKRI_DAILY_LIMIT=50
INSTAHYRE_DAILY_LIMIT=100
INDEED_DAILY_LIMIT=50
COMPANY_ATS_DAILY_LIMIT=100

# Paths
RESUME_PATH=C:/path/to/your/resume.pdf
PROFILE_PATH=./config/profile.yaml
SETTINGS_PATH=./config/settings.yaml
